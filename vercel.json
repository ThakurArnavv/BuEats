{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "foodcampus/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "foodcampus/dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/foodcampus/dist/index.html"
    }
  ]
}
